// Program 4: Reverse elements of an array, Matrix multiplication, Transpose

void reverseArray(int arr[], int n) {
    for (int i = 0; i < n / 2; i++)
        swap(arr[i], arr[n - i - 1]);
}

void multiplyMatrices(int a[10][10], int b[10][10], int res[10][10], int r1, int c1, int r2, int c2) {
    if (c1 != r2) { cout << "Multiplication not possible.\n"; return; }
    for (int i = 0; i < r1; i++)
        for (int j = 0; j < c2; j++) {
            res[i][j] = 0;
            for (int k = 0; k < c1; k++)
                res[i][j] += a[i][k] * b[k][j];
        }
}

void transposeMatrix(int mat[10][10], int rows, int cols) {
    for (int i = 0; i < cols; i++) {
        for (int j = 0; j < rows; j++)
            cout << mat[j][i] << " ";
        cout << "\n";
    }
}

// Program 5: Find sum of every row and every column in a 2D array

void sumRowsCols() {
    int rows, cols;
    int arr[10][10];

    cout << "Enter number of rows: ";
    cin >> rows;
    cout << "Enter number of columns: ";
    cin >> cols;

    cout << "Enter matrix elements:\n";
    for (int i = 0; i < rows; i++)
        for (int j = 0; j < cols; j++)
            cin >> arr[i][j];

    cout << "\nSum of each row:\n";
    for (int i = 0; i < rows; i++) {
        int rowSum = 0;
        for (int j = 0; j < cols; j++)
            rowSum += arr[i][j];
        cout << "Row " << i + 1 << ": " << rowSum << "\n";
    }

    cout << "\nSum of each column:\n";
    for (int j = 0; j < cols; j++) {
        int colSum = 0;
        for (int i = 0; i < rows; i++)
            colSum += arr[i][j];
        cout << "Column " << j + 1 << ": " << colSum << "\n";
    }
}

