#include <iostream>
#include <stdio.h>
using namespace std;

int arr1[100], n1 = 0;

// CREATE
void createArray() {
    cout << "Enter number of elements: ";
    cin >> n1;
    cout << "Enter elements: ";
    for (int i = 0; i < n1; i++) cin >> arr1[i];
}

// DISPLAY
void displayArray() {
    if (n1 == 0) { cout << "Array is empty.\n"; return; }
    cout << "Array: ";
    for (int i = 0; i < n1; i++) cout << arr1[i] << " ";
    cout << "\n";
}

// INSERT
void insertElement() {
    if (n1 >= 100) { cout << "Array full.\n"; return; }
    int pos, val;
    cout << "Enter position: "; cin >> pos;
    if (pos < 1 || pos > n1 + 1) { cout << "Invalid.\n"; return; }
    cout << "Enter value: "; cin >> val;
    for (int i = n1; i >= pos; i--) arr1[i] = arr1[i - 1];
    arr1[pos - 1] = val; n1++;
}

// DELETE
void deleteElement() {
    if (n1 == 0) { cout << "Empty.\n"; return; }
    int pos; cout << "Enter position: "; cin >> pos;
    if (pos < 1 || pos > n1) { cout << "Invalid.\n"; return; }
    for (int i = pos - 1; i < n1 - 1; i++) arr1[i] = arr1[i + 1];
    n1--;
}

// LINEAR SEARCH
void linearSearch() {
    if (n1 == 0) { cout << "Empty.\n"; return; }
    int key; cout << "Enter value: "; cin >> key;
    for (int i = 0; i < n1; i++)
        if (arr1[i] == key) { cout << "Found at position " << i + 1 << "\n"; return; }
    cout << "Not found.\n";
}

// Program 2: Remove duplicate elements from an array so only unique elements remain

void removeDuplicates(int arr[], int &n) {
    for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; ) {
            if (arr[i] == arr[j]) {
                for (int k = j; k < n - 1; k++) arr[k] = arr[k + 1];
                n--;
            } else {
                j++;
            }
        }
    }
}

